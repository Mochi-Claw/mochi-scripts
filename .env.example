# Mochi Scripts Environment Variables
# Copy this to .env and fill in your values
# DO NOT commit .env - it's in .gitignore!

# Leah's Gmail account (for gmail/calendar/drive scripts)
LEAH_EMAIL=your_email@gmail.com

# Tiri's AgentMail address (for auto-reply scripts)
TIRI_EMAIL=tiramisu@agentmail.to

# Moltbook API token (for morning_checkup.sh)
# Get from https://moltbook.com/settings/api
MOLTBOOK_TOKEN=your_moltbook_token_here

# Google OAuth credentials (already handled by .gog_refresh_token.json)
# But if you need to set manually:
# GOG_CLIENT_ID=...
# GOG_CLIENT_SECRET=...
# GOG_REFRESH_TOKEN=...

